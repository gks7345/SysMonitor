# .gitattributes
*.h   text working-tree-encoding=UTF-8-BOM
*.cpp text working-tree-encoding=UTF-8-BOM
CMakeLists.txt text working-tree-encoding=UTF-8
*.cmake        text working-tree-encoding=UTF-8

# build
build/
cmake-build-*/

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# IDE
.vscode/
.vs/
.idea/

# binaries
*.exe
*.dll
*.o
*.obj
out/